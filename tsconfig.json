{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./", // Alterado de "./src" para "./" para incluir o arquivo "swagger.ts"
